package JC;

public class Test {
	
	public static void main(String args[]) {
		
		//step 0: enter for loop
		//step 1: declare i
		//step 2: assign 0 into i
		//step 3: compare i and x
		//step 4: true proceed inside for loop
		for(int i=0; i<3; i++) {
		//step 5: print "Hello"
			System.out.println("Hello");
		}
		//step 6: add 1 to i (highlight i++)
		//step 7: return to step 5 and repeat until step 6 is false
		
		
		
		
		
		//step 0: declare j
		//step 1: assign 0 to j
		int j=0;
		
		//step 2: enter while loop
		//step 3: compare j and x
		//step 4: if true enter while loop
		while(j<3) {
		//step 5: print "world"	
			System.out.println("World");
		//step 6: add 1 to j
			j++;
		}
		//step 7: return to step 5 and repeat until step 6 is false
		
		
		//step 0: declare current
		//step 1: assign 0 to current
		//step 2 enter do
		
		int current =0;
		do {
		//step 3: print "xD"
		//step 4: add 1 to current
		
			System.out.println("xD");
			current++;
		}while(current < 3);
		//step 5: check while condition
		//step 6: if true return to step 2 until false
	}
}
